#!/usr/bin/env bash
# Pre-commit hook for building-in-the-open artifact quality gates.
# Install: cp hooks/pre-commit-docs .git/hooks/pre-commit
# Or add to your existing pre-commit hook.
#
# Requires: bito binary (cargo install bito)

set -euo pipefail

BITO="${BITO:-bito}"

# Check if bito is available
if ! command -v "$BITO" &>/dev/null; then
    echo "Warning: bito not found. Skipping doc quality checks."
    echo "Install with: cargo binstall bito | brew install claylo/brew/bito | npm i -g @claylo/bito"
    exit 0
fi

FAILED=0

# Check staged handoff files: token budget + completeness
for file in $(git diff --cached --name-only --diff-filter=ACM | grep '\.handoffs/.*\.md$'); do
    "$BITO" tokens "$file" --budget 2000 || FAILED=1
    "$BITO" completeness "$file" --template handoff || FAILED=1
done

# Check staged ADR files: completeness
for file in $(git diff --cached --name-only --diff-filter=ACM | grep 'record/decisions/.*\.md$'); do
    "$BITO" completeness "$file" --template adr || FAILED=1
done

# Check staged design doc files: completeness + readability
for file in $(git diff --cached --name-only --diff-filter=ACM | grep 'record/designs/.*\.md$'); do
    "$BITO" completeness "$file" --template design-doc || FAILED=1
    "$BITO" readability "$file" --max-grade 12 || FAILED=1
done

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo "Doc quality checks failed. Fix the issues above before committing."
    exit 1
fi
